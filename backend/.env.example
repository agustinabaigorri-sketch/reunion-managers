# Copiá este archivo a .env y completá los valores

# Postgres (Railway te da esta URL; en local, la del contenedor de Docker)
DATABASE_URL=postgres://postgres:rmpass@localhost:5433/reunion_managers

# Secreto para firmar los JWT de sesión (poné una cadena larga y aleatoria)
JWT_SECRET=cambiame-por-algo-largo-y-secreto

# Admin inicial: email + contraseña con la que entrás la primera vez.
# El resto de los usuarios los crea el admin desde la pantalla de Administración.
SEED_ADMIN_EMAIL=tu-email@educabot.com
SEED_ADMIN_PASSWORD=cambiar123

# Puerto del backend (4400 para no chocar con el backend local de FCC)
PORT=4400

# Origen permitido para CORS (URL del frontend en dev · 5273 para no chocar con FCC)
CORS_ORIGIN=http://localhost:5273
